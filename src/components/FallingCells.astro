---
// Drops 48px CMYK cells along the splash-grid columns and lets them
// pile at the bottom of the page. Mounts inside whatever element it's
// placed in — that element becomes the physics world.
---

<div data-falling-cells class="absolute inset-0 overflow-hidden pointer-events-none -z-10">
  <canvas data-falling-cells-canvas class="block w-full h-full"></canvas>
</div>

<script>
  import { startFallingCells } from '@/scripts/falling-cells';

  const container = document.querySelector('[data-falling-cells]') as HTMLElement | null;
  const canvas = document.querySelector('[data-falling-cells-canvas]') as HTMLCanvasElement | null;
  if (container && canvas) {
    startFallingCells(canvas, container);
  }
</script>
