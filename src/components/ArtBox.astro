---
interface Props {
  elements: string[];
  class?: string;
}

const { elements, class: className = '' } = Astro.props;
---

<canvas
  data-art-box
  data-elements={JSON.stringify(elements)}
  class:list={['block w-full aspect-square', className]}
></canvas>

<script>
  import { mountArtBox } from '@/scripts/art-box';

  document.querySelectorAll<HTMLCanvasElement>('canvas[data-art-box]').forEach((canvas) => {
    const elements = JSON.parse(canvas.dataset.elements ?? '[]') as string[];
    mountArtBox(canvas, elements);
  });
</script>
