---
import Base from '@/layouts/Base.astro';
import ShaderBackground from '@/components/ShaderBackground.astro';
---

<Base title="Bobby Meyer">
  <header class="relative w-full h-[320px] md:h-[420px] overflow-hidden">
    <ShaderBackground shader="swiss" />
  </header>

  <main class="bg-paper text-ink">
    <section class="max-w-3xl mx-auto px-6 md:px-10 pt-20 md:pt-28 pb-16">
      <p class="font-grotesk text-xs uppercase tracking-[0.3em] mb-10">
        This is just about me
      </p>
      <p class="font-grotesk text-3xl md:text-5xl leading-tight tracking-tight">
        I wrangle bits. I manipulate pixels, waveforms, and lines of code.
      </p>
      <p class="font-grotesk text-3xl md:text-5xl leading-tight tracking-tight mt-6 text-ink/70">
        I'm old enough to have called that multimedia.
      </p>
    </section>

    <section class="max-w-3xl mx-auto px-6 md:px-10 py-12">
      <ul class="grid grid-cols-3 gap-6 text-xs uppercase tracking-[0.3em]">
        <li><a href="#work" class="hover:opacity-60 transition-opacity">work</a></li>
        <li><a href="#writing" class="hover:opacity-60 transition-opacity">writing</a></li>
        <li><a href="#contact" class="hover:opacity-60 transition-opacity">contact</a></li>
      </ul>
    </section>

    <section id="work" class="max-w-3xl mx-auto px-6 md:px-10 py-24">
      <h2 class="font-grotesk text-xs uppercase tracking-[0.3em] mb-8">Work</h2>
      <p class="text-base leading-relaxed text-ink/70">
        Placeholder.
      </p>
    </section>

    <section id="writing" class="max-w-3xl mx-auto px-6 md:px-10 py-24">
      <h2 class="font-grotesk text-xs uppercase tracking-[0.3em] mb-8">Writing</h2>
      <p class="text-base leading-relaxed text-ink/70">
        Placeholder.
      </p>
    </section>

    <section id="contact" class="max-w-3xl mx-auto px-6 md:px-10 py-24">
      <h2 class="font-grotesk text-xs uppercase tracking-[0.3em] mb-8">Contact</h2>
      <p class="text-base leading-relaxed text-ink/70">
        Placeholder.
      </p>
    </section>

    <footer class="max-w-3xl mx-auto px-6 md:px-10 py-12 text-xs uppercase tracking-[0.3em] text-ink/50">
      © {new Date().getFullYear()} Bobby Meyer
    </footer>
  </main>
</Base>
