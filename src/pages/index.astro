---
import { getCollection } from 'astro:content';
import Base from '@/layouts/Base.astro';

const posts = (await getCollection('posts')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const fillerCells = Array.from({ length: 96 });
---

<Base title="Bobby Meyer">
  <main class="mx-auto max-w-6xl px-4 py-8">
    <div
      class="grid grid-flow-dense grid-cols-[repeat(auto-fill,minmax(96px,1fr))] gap-4"
    >
      <!-- Badge: top-right, 3x2 cells -->
      <div
        class="[grid-column:span_3/-1] [grid-row:1/span_2] flex items-center justify-center bg-yellow-400 font-sans font-bold text-2xl md:text-3xl tracking-tight leading-tight text-center px-2"
      >
        bobby meyer
      </div>

      <!-- One tile per post, sized from frontmatter (defaults 2x2). -->
      {posts.map((post) => (
        <a
          href={`/posts/${post.slug}/`}
          style={`grid-column: span ${post.data.width}; grid-row: span ${post.data.height};`}
          class="flex flex-col justify-between border border-dashed border-black/40 p-3 hover:border-black hover:bg-black/5 transition-colors"
        >
          <span class="text-[10px] uppercase tracking-[0.25em] text-black/60">
            {post.data.date.toISOString().slice(0, 10)}
          </span>
          <span class="font-bold text-base leading-tight">
            {post.data.title}
          </span>
        </a>
      ))}

      <!-- Filler cells set the row track height (aspect-square) so post
           tiles spanning multiple rows come out square too. -->
      {fillerCells.map(() => (
        <div class="aspect-square border border-dashed border-black/30"></div>
      ))}
    </div>
  </main>
</Base>
