---
import Base from '@/layouts/Base.astro';
import ShaderBackground from '@/components/ShaderBackground.astro';
---

<Base title="Bobby Meyer">
  <header class="relative w-full h-[320px] md:h-[420px] overflow-hidden border-b border-ink/20">
    <ShaderBackground shader="swiss" />
  </header>

  <main class="bg-paper text-ink">
    <div class="max-w-3xl mx-auto px-6 md:px-10 py-16">
      <p class="text-lg leading-relaxed">
        Page content goes here.
      </p>
    </div>
  </main>
</Base>
