---
import Base from '@/layouts/Base.astro';
import ShaderBackground from '@/components/ShaderBackground.astro';
import FallingCells from '@/components/FallingCells.astro';
---

<Base title="Bobby Meyer">
  <header class="relative w-full h-[320px] md:h-[420px] overflow-hidden">
    <ShaderBackground shader="swiss" />
  </header>

  <main class="relative">
    <FallingCells />

    <!-- Contact form sits at the top so the typing-pushes-cells trick
         is the first thing you can play with after the masthead. -->
    <section id="contact" class="relative max-w-2xl mx-auto px-6 md:px-10 pt-20 md:pt-28 pb-12 md:pb-16">
      <h2 data-collide class="inline-block font-grotesk text-xs uppercase tracking-[0.3em] mb-10">
        Get in touch
      </h2>

      <form
        name="contact"
        method="POST"
        data-netlify="true"
        netlify-honeypot="bot-field"
        class="space-y-6"
      >
        <input type="hidden" name="form-name" value="contact" />
        <p class="hidden">
          <label>Don't fill this out: <input name="bot-field" /></label>
        </p>

        <div class="space-y-2">
          <label for="name" class="block text-xs uppercase tracking-[0.3em] text-ink/60">
            Name
          </label>
          <input
            data-collide
            type="text"
            id="name"
            name="name"
            required
            class="w-full bg-transparent border-b border-ink/30 focus:border-ink py-2 outline-none transition-colors"
          />
        </div>

        <div class="space-y-2">
          <label for="email" class="block text-xs uppercase tracking-[0.3em] text-ink/60">
            Email
          </label>
          <input
            data-collide
            type="email"
            id="email"
            name="email"
            required
            class="w-full bg-transparent border-b border-ink/30 focus:border-ink py-2 outline-none transition-colors"
          />
        </div>

        <div class="space-y-2">
          <label for="message" class="block text-xs uppercase tracking-[0.3em] text-ink/60">
            Message
          </label>
          <textarea
            data-collide
            id="message"
            name="message"
            rows="5"
            required
            class="w-full bg-transparent border-b border-ink/30 focus:border-ink py-2 outline-none transition-colors resize-none"
          ></textarea>
        </div>

        <button
          data-collide
          type="submit"
          class="text-xs uppercase tracking-[0.3em] border border-ink px-8 py-3 hover:bg-ink hover:text-paper transition-colors"
        >
          Send
        </button>
      </form>
    </section>

    <!-- Below: bio left, portrait right. -->
    <section class="relative max-w-6xl mx-auto px-6 md:px-10 py-16 md:py-24">
      <div class="grid grid-cols-12 gap-x-10 gap-y-16 items-start">
        <!-- Bio + patter -->
        <div class="col-span-12 md:col-span-7 md:row-start-1">
          <p data-collide class="font-grotesk text-xs uppercase tracking-[0.3em] mb-10 inline-block">
            This is just about me
          </p>
          <p data-collide class="font-grotesk text-3xl md:text-5xl leading-tight tracking-tight">
            I wrangle bits. I manipulate pixels, waveforms, and lines of code.
          </p>
          <p data-collide class="font-grotesk text-3xl md:text-5xl leading-tight tracking-tight mt-6 text-ink/70">
            I'm old enough to have called that multimedia.
          </p>

          <div class="mt-16 max-w-md md:max-w-lg space-y-5 text-base leading-relaxed text-ink/80">
            <p data-collide>
              I've spent the better part of a career on the line between
              design and engineering — making things that look the way
              they should and behave the way they should, even when the
              deadline disagrees.
            </p>
            <p data-collide>
              Lately that's mostly the web. Yesterday it was print, album
              art, synthesizers, and whatever the kids might call motion
              graphics now. I still call it After Effects.
            </p>
            <p data-collide>
              I keep a long list of half-finished projects and a short
              list of finished ones. Both grow. This site is a place to
              point at the finished ones, and occasionally to think out
              loud.
            </p>
          </div>
        </div>

        <!-- Portrait -->
        <div
          data-collide
          data-collide-shape="/img/bobby-sidebar.png"
          class="col-span-12 md:col-span-5 md:col-start-8 md:row-start-1 aspect-[4/5] overflow-hidden"
        >
          <img
            src="/img/bobby-sidebar.png"
            alt="Bobby Meyer"
            class="h-full w-full object-cover object-top"
          />
        </div>
      </div>
    </section>

    <footer class="max-w-3xl mx-auto px-6 md:px-10 py-12 text-xs uppercase tracking-[0.3em] text-ink/50">
      <span data-collide class="inline-block">© {new Date().getFullYear()} Bobby Meyer</span>
    </footer>
  </main>
</Base>
