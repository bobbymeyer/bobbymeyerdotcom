---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'bobbymeyer.com' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Inter is the Linux / Chrome OS fallback for systems without
         Helvetica or Arial — same grotesk feel. -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class="min-h-screen font-grotesk antialiased bg-paper text-ink">
    <slot />
  </body>
</html>
